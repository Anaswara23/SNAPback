rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own doc
    match /users/{uid} {
      allow read, write: if request.auth.uid == uid;

      // Users can read/write their own trips
      match /trips/{tripId} {
        allow read: if request.auth.uid == uid;
        
        // Only create (not update scores — that's Cloud Functions)
        allow create: if request.auth.uid == uid
          && request.resource.data.status == 'uploading';
      }
    }

    // Food cache is read-only for authenticated users
    match /foodCache/{itemId} {
      allow read: if request.auth != null;
      allow write: if false; // Cloud Functions only
    }
  }
}
